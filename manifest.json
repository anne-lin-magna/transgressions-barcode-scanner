{
  "trafmanPwaLaunchFileName": "launch.trafman",
  "id": "trafman-reports",
  "name": "Trafman Reports",
  "short_name": "TM Reports",
  "description": "The Trafman Reports subsystem.",
  "start_url": "/reports/",
  "scope": "/reports/",
  "display": "standalone",
  "launch_handler": {
    "client_mode": [
      "focus-existing",
      "auto"
    ]
  },
  "background_color": "#555",
  "theme_color": "#777",
  "icons": [
    {
      "src": "/reports/pwa/192.png",
      "type": "image/png",
      "sizes": "192x192"
    },
    {
      "src": "/reports/pwa/512.png",
      "type": "image/png",
      "sizes": "512x512"
    }
  ],
  "screenshots": [
    {
      "src": "/reports/pwa/intro-small.png",
      "sizes": "480x320",
      "type": "image/png",
      "label": "Trafman Subsystem"
    },
    {
      "src": "/reports/pwa/intro-large.png",
      "sizes": "768x512",
      "type": "image/png",
      "label": "Trafman Subsystem",
      "form_factor": "wide"
    }
  ],
  "shortcuts": [
    {
      "name": "Profile",
      "description": "Open the User Profile page.",
      "icons": [
        {
          "src": "/reports/pwa/96.png",
          "type": "image/png",
          "sizes": "96x96"
        }
      ],
      "url": "/reports/profile"
    },
    {
      "name": "Reports",
      "description": "Open the Reports page.",
      "icons": [
        {
          "src": "/reports/pwa/96.png",
          "type": "image/png",
          "sizes": "96x96"
        }
      ],
      "url": "/reports/reports"
    }
  ],
  "file_handlers": [
    {
      "accept": {
        "application/x-trafman": [
          ".trafman"
        ]
      },
      "action": "/reports/"
    }
  ]
}
